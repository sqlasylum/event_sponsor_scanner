# Copy this file to .env and fill in the values

# Display name shown on the status page
EVENT_NAME=Event Sponsor Scanner

# Admin password for /admin/* routes (username is always "admin")
ADMIN_PASSWORD=change-me

# PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://scanner:scanner@db:5432/scanner

# Secret key for signing session cookies — generate with: openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# Public URL of the service (used to build QR code links)
BASE_URL=http://localhost:8000

# Optional: Bearer token to protect /admin/* routes (leave empty to disable auth)
ADMIN_TOKEN=
